<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.game.projekgame.controller.DashboardController">

    <top>

        <VBox alignment="CENTER">

            <padding>
                <Insets top="20" bottom="20"/>
            </padding>

            <Label text="⚔ MONSTER COLLECTION GAME ⚔"
                   styleClass="title-label"/>

        </VBox>

    </top>

    <center>

        <VBox alignment="CENTER"
              spacing="25">

            <VBox alignment="CENTER"
                  spacing="12"
                  styleClass="monster-card">

                <padding>
                    <Insets top="25"
                            right="40"
                            bottom="25"
                            left="40"/>
                </padding>

                <Label fx:id="monsterEmojiLabel"
                       text="🔥"
                       style="-fx-font-size:80px;"/>

                <Label fx:id="monsterLabel"
                       style="-fx-font-size:28px;
                              -fx-font-weight:bold;"/>

                <Label fx:id="levelLabel"/>

                <Label fx:id="hpLabel"/>

                <Label fx:id="attackLabel"/>

                <Label fx:id="defenseLabel"/>

                <Label fx:id="scoreLabel"/>

                <Label text="❤️ HP"/>

                <ProgressBar fx:id="hpBar"
                             prefWidth="300"/>

                <Label text="⭐ EXP"/>

                <ProgressBar fx:id="expBar"
                             prefWidth="300"/>

                <Label fx:id="expLabel"/>

            </VBox>

            <HBox alignment="CENTER"
                  spacing="20">

                <Button text="🌍 Explore"
                        prefWidth="220"
                        prefHeight="50"
                        onAction="#handleExplore"/>

                <Button text="🎒 My Monsters"
                        prefWidth="220"
                        prefHeight="50"
                        onAction="#handleCollection"/>

            </HBox>

            <HBox alignment="CENTER"
                  spacing="20">

                <Button text="🏆 Leaderboard"
                        prefWidth="220"
                        prefHeight="50"
                        onAction="#handleLeaderboard"/>

                <Button text="🚪 Logout"
                        prefWidth="220"
                        prefHeight="50"
                        onAction="#handleLogout"/>

            </HBox>

        </VBox>

    </center>

</BorderPane>