<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.game.projekgame.controller.ExploreController">

    <top>

        <VBox alignment="CENTER">

            <padding>
                <Insets top="20" bottom="20"/>
            </padding>

            <Label text="🌍 EXPLORE AREA"
                   styleClass="title-label"/>

        </VBox>

    </top>

    <center>

        <VBox alignment="CENTER"
              spacing="30">

            <VBox alignment="CENTER"
                  spacing="15"
                  styleClass="monster-card">

                <padding>
                    <Insets top="30"
                            right="50"
                            bottom="30"
                            left="50"/>
                </padding>

                <Label text="👹"
                       style="-fx-font-size:80px;"/>

                <Label text="Wild Monster Found!"
                       style="-fx-font-size:24px;
                              -fx-font-weight:bold;"/>

                <Label fx:id="wildMonsterLabel"
                       style="-fx-font-size:26px;"/>

            </VBox>

            <HBox alignment="CENTER"
                  spacing="20">

                <Button fx:id="fightButton"
                        text="⚔ Fight"
                        prefWidth="180"
                        prefHeight="50"
                        onAction="#handleFight"/>

                <Button fx:id="captureButton"
                        text="🎯 Capture"
                        prefWidth="180"
                        prefHeight="50"
                        onAction="#handleCapture"/>

            </HBox>

            <Button fx:id="backButton"
                    text="🏠 Dashboard"
                    prefWidth="250"
                    prefHeight="50"
                    onAction="#handleBack"/>

        </VBox>

    </center>

</BorderPane>