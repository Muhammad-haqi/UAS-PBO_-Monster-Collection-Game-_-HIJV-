<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.game.projekgame.controller.BattleController">

    <top>

        <VBox alignment="CENTER">

            <padding>
                <Insets top="20" bottom="20"/>
            </padding>

            <Label text="⚔ DRAGON CITY BATTLE ⚔"
                   styleClass="title-label"/>

        </VBox>

    </top>

    <center>

        <VBox alignment="CENTER"
              spacing="25">

            <Label text="⚔ YOUR TEAM"
                   style="-fx-font-size:20px;
                          -fx-font-weight:bold;
                          -fx-text-fill:white;"/>

            <Label fx:id="teamLabel"
                   style="-fx-font-size:16px;
                          -fx-text-fill:white;"/>

            <HBox alignment="CENTER"
                  spacing="120">

                <VBox alignment="CENTER"
                      spacing="10"
                      styleClass="monster-card">

                    <padding>
                        <Insets top="20"
                                right="30"
                                bottom="20"
                                left="30"/>
                    </padding>

                    <Label fx:id="playerEmojiLabel"
                           style="-fx-font-size:70px;"/>

                    <Label fx:id="playerMonsterLabel"/>

                    <ProgressBar fx:id="playerHpBar"
                                 prefWidth="250"/>

                    <Label fx:id="playerHpLabel"/>

                </VBox>

                <Label text="VS"
                       style="-fx-font-size:40px;
                              -fx-font-weight:bold;
                              -fx-text-fill:white;"/>

                <VBox alignment="CENTER"
                      spacing="10"
                      styleClass="monster-card">

                    <padding>
                        <Insets top="20"
                                right="30"
                                bottom="20"
                                left="30"/>
                    </padding>

                    <Label text="👹"
                           style="-fx-font-size:70px;"/>

                    <Label fx:id="enemyMonsterLabel"/>

                    <ProgressBar fx:id="enemyHpBar"
                                 prefWidth="250"/>

                    <Label fx:id="enemyHpLabel"/>

                </VBox>

            </HBox>

            <Label fx:id="battleInfoLabel"
                   style="-fx-font-size:18px;
                          -fx-text-fill:white;"/>

            <HBox spacing="20"
                  alignment="CENTER">

                <Button text="⚔ ATTACK"
                        prefWidth="180"
                        onAction="#handleAttack"/>

                <Button text="🔄 SWAP"
                        prefWidth="180"
                        onAction="#handleSwap"/>

            </HBox>

            <HBox spacing="20"
                  alignment="CENTER">

                <Button fx:id="fightAgainButton"
                        text="⚔ FIGHT AGAIN"
                        visible="false"
                        managed="false"
                        prefWidth="200"
                        onAction="#handleFightAgain"/>

                <Button fx:id="backButton"
                        text="🏠 DASHBOARD"
                        visible="false"
                        managed="false"
                        prefWidth="200"
                        onAction="#handleBackToDashboard"/>

            </HBox>

        </VBox>

    </center>

</BorderPane>